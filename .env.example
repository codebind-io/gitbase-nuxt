# Copy this file and rename the copy to .env.cloudflare, then fill in your values.
# After creating your Cloudflare Pages project, upload secrets with:
# npx wrangler pages secret bulk .env.cloudflare --project-name PROJECT_NAME

GITBASE_CODEBASE_URL=https://cdn.gitbase.cloud/gitbase-main.js
GITBASE_SITE_URL=http://localhost:3000

GITBASE_GITHUB_REPO=owner/repo
GITBASE_GITHUB_BRANCH=main
GITBASE_GITHUB_PAT=

GITBASE_GOOGLE_CLIENT_ID=
GITBASE_ALLOWED_EMAILS=

GITBASE_DEPLOY_HOOK_URL=

GITBASE_R2_ACCESS_KEY_ID=
GITBASE_R2_SECRET_ACCESS_KEY=
GITBASE_R2_BUCKET=
GITBASE_R2_ACCOUNT_ID=
GITBASE_R2_PUBLIC_URL=
GITBASE_R2_PREFIX=gitbase/
GITBASE_R2_JURISDICTION=default

#GITBASE_PEXELS=
#GITBASE_PIXABAY=
#GITBASE_UNSPLASH=
